    "name": "Batterie",
    "label": "Batterie",
    "format": "{{value}}%",
    "min": 0,
    "max": 100,
    "colors": ["#e74c3c", "#f39c12", "#2ecc71"],
    "seg1": 20,
    "seg2": 50,
    "wires": []
