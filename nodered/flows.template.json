[
  {
    "id": "broker1",
    "type": "mqtt-broker",
    "name": "Mosquitto",
    "broker": "mosquitto",
    "port": "1883",
    "clientid": "nodered-silence",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4"
  },
  {
    "id": "tab1",
    "type": "ui_tab",
    "name": "Scooter",
    "icon": "dashboard",
    "order": 1
  },
  {
    "id": "g-etat",
    "type": "ui_group",
    "name": "Etat",
    "tab": "tab1",
    "order": 1,
    "disp": true,
    "width": "6"
  },
  {
    "id": "g-bat",
    "type": "ui_group",
    "name": "Batterie",
    "tab": "tab1",
    "order": 2,
    "disp": true,
    "width": "6"
  },
  {
    "id": "g-perf",
    "type": "ui_group",
    "name": "Performances",
    "tab": "tab1",
    "order": 3,
    "disp": true,
    "width": "6"
  },
  {
    "id": "g-temp",
    "type": "ui_group",
    "name": "Temperatures",
    "tab": "tab1",
    "order": 4,
    "disp": true,
    "width": "6"
  },
  {
    "id": "g-cmd",
    "type": "ui_group",
    "name": "Commandes",
    "tab": "tab1",
    "order": 5,
    "disp": true,
    "width": "12"
  },
  {
    "id": "mqtt-in",
    "type": "mqtt in",
    "name": "Status",
    "topic": "home/silence-server/+/status",
    "qos": "0",
    "datatype": "json",
    "broker": "broker1",
    "x": 100,
    "y": 100,
    "wires": [["fn1"]]
  },
  {
    "id": "fn1",
    "type": "function",
    "name": "Extraire",
    "func": "var d=msg.payload;\nvar s={0:'Eteint',1:'Veille',2:'Demarrage',3:'Pret',4:'En route',5:'En charge'};\nnode.send([\n  [{payload:s[d.status]||('?'+d.status)}],\n  [{payload:parseFloat(d.odo||0).toFixed(1)+' km'}],\n  [{payload:d.BatterySoC||0}],\n  [{payload:parseFloat(d.range||0).toFixed(0)+' km'}],\n  [{payload:d.charging?'En charge':(d.batteryOut?'Batterie sortie':'Normal')}],\n  [{payload:Math.round(d.velocity||0)}],\n  [{payload:d.motorTemperature||0}],\n  [{payload:d.inverterTemperature||0}],\n  [{payload:d.batteryTemperature||0}]\n]);",
    "outputs": 9,
    "x": 300,
    "y": 100,
    "wires": [
      ["txt-status"],
      ["txt-odo"],
      ["g-battery"],
      ["txt-range"],
      ["txt-charge"],
      ["g-speed"],
      ["g-tmot"],
      ["g-tinv"],
      ["g-tbat"]
    ]
  },
  {
    "id": "txt-status",
    "type": "ui_text",
    "group": "g-etat",
    "order": 1,
    "name": "Etat",
    "label": "Etat",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "wires": []
  },
  {
    "id": "txt-odo",
    "type": "ui_text",
    "group": "g-etat",
    "order": 2,
    "name": "Kilometrage",
    "label": "Kilometrage",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "wires": []
  },
  {
    "id": "g-battery",
    "type": "ui_gauge",
    "group": "g-bat",
